<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Windows 11 Glass Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#202020"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="#383838"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#60CDFF"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#999999"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#6CCB5F"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FCE100"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#F85149"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#404040"/>

    <!-- Glass Card Brush (semi-transparent) -->
    <SolidColorBrush x:Key="GlassBrush" Color="#15FFFFFF"/>
    <SolidColorBrush x:Key="GlassHoverBrush" Color="#20FFFFFF"/>

</ResourceDictionary>
