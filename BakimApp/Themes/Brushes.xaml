<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Glass Effect Brushes -->
    <SolidColorBrush x:Key="GlassLightBrush" Color="#08FFFFFF"/>
    <SolidColorBrush x:Key="GlassMediumBrush" Color="#12FFFFFF"/>
    <SolidColorBrush x:Key="GlassDarkBrush" Color="#1AFFFFFF"/>

    <!-- Premium Card Shadow -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.3"/>
    <DropShadowEffect x:Key="GlowEffect" BlurRadius="15" ShadowDepth="0" Color="#6366F1" Opacity="0.4"/>

</ResourceDictionary>
