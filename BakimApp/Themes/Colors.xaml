<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Windows 11 Dark Theme Colors -->
    <Color x:Key="BackgroundColor">#202020</Color>
    <Color x:Key="SurfaceColor">#2D2D2D</Color>
    <Color x:Key="SurfaceLightColor">#383838</Color>
    <Color x:Key="AccentColor">#60CDFF</Color>
    <Color x:Key="AccentDarkColor">#0078D4</Color>
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#999999</Color>
    <Color x:Key="SuccessColor">#6CCB5F</Color>
    <Color x:Key="WarningColor">#FCE100</Color>
    <Color x:Key="ErrorColor">#F85149</Color>
    <Color x:Key="BorderColor">#404040</Color>

</ResourceDictionary>
