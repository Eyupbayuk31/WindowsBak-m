<Window x:Class="BakimApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BakimApp"
        xmlns:vm="clr-namespace:BakimApp.ViewModels"
        xmlns:pages="clr-namespace:BakimApp.Views.Pages"
        mc:Ignorable="d"
        Title="BakimApp" Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <!-- Navigation Button Style -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Main Container -->
        <Border CornerRadius="8" Background="#202020" BorderBrush="#404040" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Border Grid.Row="0" Background="Transparent" CornerRadius="8,8,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="16,0">
                        <!-- App Icon & Title -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="24" Height="24" CornerRadius="4" Background="#60CDFF" Margin="0,0,10,0">
                                <TextBlock Text="B" FontSize="14" FontWeight="Bold"
                                           Foreground="#202020" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="BakimApp" FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Window Controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Width="46" Height="32" Click="MinimizeButton_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#999999" Cursor="Hand">
                                <Path Data="M0,6 L12,6" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1" Width="12" Height="12" Stretch="None"/>
                            </Button>
                            <Button Width="46" Height="32" Click="MaximizeRestoreButton_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#999999" Cursor="Hand">
                                <Grid Width="12" Height="12">
                                    <Rectangle Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               StrokeThickness="1" Width="10" Height="10"/>
                                </Grid>
                            </Button>
                            <Button Width="46" Height="32" Click="CloseButton_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#999999" Cursor="Hand">
                                <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1" Width="10" Height="10" Stretch="None"/>
                            </Button>
                            <Button Width="46" Height="32" Click="CloseButton_Click"
                                    Background="#E81123" BorderThickness="0"
                                    Foreground="White" Cursor="Hand" Opacity="0"
                                    IsHitTestVisible="False"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content Area -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar Navigation -->
                    <Border Grid.Column="0" Background="#151515" CornerRadius="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="12,16,12,12">
                                <!-- Nav Header -->
                                <TextBlock Text="ANA MENÜ" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#666666" Margin="12,0,0,12"/>

                                <RadioButton Style="{StaticResource NavButton}"
                                             IsChecked="{Binding IsDashboardSelected, Mode=OneWay}"
                                             Command="{Binding NavigateToDashboardCommand}"
                                             GroupName="Nav">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M3,13h8V3H3V13z M3,21h8v-6H3V21z M13,21h8V11h-8V21z M13,3v6h8V3H13z"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton Style="{StaticResource NavButton}"
                                             IsChecked="{Binding IsCleaningSelected, Mode=OneWay}"
                                             Command="{Binding NavigateToCleaningCommand}"
                                             GroupName="Nav">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M19.36,2.72L20.78,4.14L15.06,9.85C16.13,11.39 16.28,13.24 15.38,14.44L9.06,8.12C10.26,7.22 12.11,7.37 13.65,8.44L19.36,2.72M5.93,17.57C3.92,15.56 2.69,13.16 2.35,10.92L7.23,8.83L14.67,16.27L12.58,21.15C10.34,20.81 7.94,19.58 5.93,17.57Z"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Temizlik" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>

                                <Border Height="1" Background="#333333" Margin="12,16"/>

                                <TextBlock Text="SİSTEM" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#666666" Margin="12,16,0,12"/>

                                <RadioButton Style="{StaticResource NavButton}" IsEnabled="False" Opacity="0.4">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"
                                              Fill="#999999" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Kayıt Defteri" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton Style="{StaticResource NavButton}" IsEnabled="False" Opacity="0.4">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                              Fill="#999999" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Başlangıç" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton Style="{StaticResource NavButton}" IsEnabled="False" Opacity="0.4">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M4,6H20V16H4M20,18A2,2 0 0,0 22,16V6C22,4.89 21.1,4 20,4H4C2.89,4 2,4.89 2,6V16A2,2 0 0,0 4,18H0V20H24V18H20Z"
                                              Fill="#999999" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Programlar" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton Style="{StaticResource NavButton}" IsEnabled="False" Opacity="0.4">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M6,2H18A2,2 0 0,1 20,4V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V4A2,2 0 0,1 6,2M12,4A6,6 0 0,0 6,10C6,13.31 8.69,16 12,16A6,6 0 0,0 18,10A6,6 0 0,0 12,4M12,8A2,2 0 0,1 14,10A2,2 0 0,1 12,12A2,2 0 0,1 10,10A2,2 0 0,1 12,8M18,20V22H6V20H18Z"
                                              Fill="#999999" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Disk Analizi" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                            <!-- Version Info at bottom -->
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#333333" Padding="16,12">
                                <RadioButton Style="{StaticResource NavButton}" IsEnabled="False" Opacity="0.4">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                              Fill="#999999" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Ayarlar" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Content Area -->
                    <Border Grid.Column="1" CornerRadius="0,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1A1A" Offset="0"/>
                                <GradientStop Color="#202020" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentControl x:Name="ContentArea" Margin="32"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
