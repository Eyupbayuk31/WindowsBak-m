<UserControl x:Class="BakimApp.Views.Pages.CleaningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BakimApp.ViewModels"
             xmlns:models="clr-namespace:BakimApp.Models"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance vm:CleaningViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,32,24">
            <TextBlock Text="Sistem Temizligi" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Gereksiz dosyalari temizleyerek sisteminizi hizlandirin"
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <!-- Categories Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Categories}" Margin="0,0,32,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:CleaningCategory}">
                        <Border Margin="0,0,12,12" Padding="20" CornerRadius="12" Cursor="Hand"
                                BorderThickness="2" MouseLeftButtonUp="Category_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#18182280"/>
                                    <Setter Property="BorderBrush" Value="#27272A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="#6366F1"/>
                                            <Setter Property="Background" Value="#1A1A2440"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.2"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Icon with risk color -->
                                <Border Grid.Row="0" Width="40" Height="40" CornerRadius="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#6366F1" Offset="0"/>
                                                        <GradientStop Color="#8B5CF6" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe Fluent Icons"
                                               FontSize="18" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Scanning Progress -->
                                <ProgressBar Grid.Row="0" Height="3" VerticalAlignment="Bottom" Margin="0,4,0,0"
                                             IsIndeterminate="True" Style="{StaticResource ModernProgress}"
                                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"/>

                                <!-- Name & Description -->
                                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#FFFFFF" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="#71717A" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Size Info -->
                                <StackPanel Grid.Row="2" Margin="0,12,0,0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding Size, Converter={StaticResource BytesToSizeConverter}, FallbackValue=0 MB}"
                                               FontSize="18" FontWeight="Bold" Foreground="#6366F1"/>
                                </StackPanel>

                                <!-- Footer: File Count + Risk -->
                                <Grid Grid.Row="3" Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="4" Padding="6,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#10FFFFFF"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RiskLevel}" Value="Safe">
                                                            <Setter Property="Background" Value="#1010B981"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RiskLevel}" Value="Caution">
                                                            <Setter Property="Background" Value="#10F59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RiskLevel}" Value="Dangerous">
                                                            <Setter Property="Background" Value="#10EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#71717A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RiskLevel}" Value="Safe">
                                                                <Setter Property="Foreground" Value="#10B981"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RiskLevel}" Value="Caution">
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RiskLevel}" Value="Dangerous">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding FileCount, StringFormat={}{0} dosya}" 
                                               FontSize="11" Foreground="#71717A" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Margin="0,16,32,0" CornerRadius="12" Padding="24,20"
                Background="#18182280" BorderBrush="#27272A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Stats -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border CornerRadius="6" Padding="10,4" Margin="0,0,10,0" Background="#10FFFFFF">
                            <TextBlock FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold">
                                <Run Text="{Binding SelectedSize, Converter={StaticResource BytesToSizeConverter}, FallbackValue=0}"/>
                                <Run Text=" secili"/>
                            </TextBlock>
                        </Border>
                        <Border CornerRadius="6" Padding="10,4" Background="#106366F1">
                            <TextBlock FontSize="12" Foreground="#6366F1" FontWeight="SemiBold">
                                <Run Text="{Binding SelectedCount}"/>
                                <Run Text=" kategori"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#71717A"/>
                    <ProgressBar Height="4" Margin="0,8,0,0" Value="{Binding Progress, Mode=OneWay}" Maximum="100"
                                 Style="{StaticResource ModernProgress}"
                                 Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"/>
                </StackPanel>

                <!-- Right: Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Tara" Style="{StaticResource GhostButton}"
                            Command="{Binding ScanCommand}" Margin="0,0,10,0"/>
                    <Button Content="Temizle" Style="{StaticResource AccentButton}"
                            Command="{Binding CleanCommand}" Margin="0,0,10,0"/>
                    <Button Content="Hepsi" Style="{StaticResource GhostButton}"
                            Command="{Binding SelectAllCommand}" Margin="0,0,10,0"/>
                    <Button Content="Iptal" Style="{StaticResource GhostButton}"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
