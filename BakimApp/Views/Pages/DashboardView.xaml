<UserControl x:Class="BakimApp.Views.Pages.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BakimApp.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,32,0">
            <!-- Header -->
            <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Sisteminizin sağlık durumunu görüntüleyin"
                       Style="{StaticResource PageSubtitle}"/>

            <!-- System Stats Cards -->
            <TextBlock Text="SİSTEM DURUMU" Style="{StaticResource SectionTitle}"/>

            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU Card -->
                <Border Grid.Column="0" Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <!-- Icon -->
                        <Border Width="40" Height="40" CornerRadius="8" Background="#20007BEF" Margin="0,0,0,16">
                            <Path Data="M3,13h8V3H3V13z M3,21h8v-6H3V21z M13,21h8V11h-8V21z M13,3v6h8V3H13z"
                                  Fill="#60CDFF" Width="20" Height="20" Stretch="Uniform"/>
                        </Border>

                        <TextBlock Text="{Binding FormattedCpuUsage}" Style="{StaticResource StatValue}"/>
                        <TextBlock Text="CPU Kullanımı" Style="{StaticResource StatLabel}"/>

                        <!-- Progress -->
                        <ProgressBar Height="4" Margin="0,16,0,0"
                                     Value="{Binding CpuUsage, Mode=OneWay}" Maximum="100"
                                     Style="{StaticResource ModernProgress}"/>
                    </StackPanel>
                </Border>

                <!-- RAM Card -->
                <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <!-- Icon -->
                        <Border Width="40" Height="40" CornerRadius="8" Background="#206CCB5F" Margin="0,0,0,16">
                            <Path Data="M17,17H7V7H17M17,1H7A2,2 0 0,0 5,3V21A2,2 0 0,0 7,23H17A2,2 0 0,0 19,21V3A2,2 0 0,0 17,1Z"
                                  Fill="#6CCB5F" Width="20" Height="20" Stretch="Uniform"/>
                        </Border>

                        <TextBlock Text="{Binding FormattedRamUsage}" Style="{StaticResource StatValue}"/>
                        <TextBlock Text="RAM Kullanımı" Style="{StaticResource StatLabel}"/>

                        <!-- Progress -->
                        <ProgressBar Height="4" Margin="0,16,0,0"
                                     Value="{Binding RamUsagePercent, Mode=OneWay}" Maximum="100"
                                     Foreground="#6CCB5F" Style="{StaticResource ModernProgress}"/>
                    </StackPanel>
                </Border>

                <!-- Disk Card -->
                <Border Grid.Column="2" Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <!-- Icon -->
                        <Border Width="40" Height="40" CornerRadius="8" Background="#20FCE100" Margin="0,0,0,16">
                            <Path Data="M6,2H18A2,2 0 0,1 20,4V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V4A2,2 0 0,1 6,2M6,4V8H18V4H6M6,20V16H18V20H6M6,12V10H18V12H6Z"
                                  Fill="#FCE100" Width="20" Height="20" Stretch="Uniform"/>
                        </Border>

                        <TextBlock Text="{Binding FormattedDiskUsage}" Style="{StaticResource StatValue}"/>
                        <TextBlock Text="Disk Kullanımı" Style="{StaticResource StatLabel}"/>

                        <!-- Progress -->
                        <ProgressBar Height="4" Margin="0,16,0,0"
                                     Value="{Binding DiskUsagePercent, Mode=OneWay}" Maximum="100"
                                     Foreground="#FCE100" Style="{StaticResource ModernProgress}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- System Info Section -->
            <TextBlock Text="SİSTEM BİLGİLERİ" Style="{StaticResource SectionTitle}"/>

            <Border Style="{StaticResource GlassCard}" Margin="0,0,16,32">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
                        <TextBlock Text="BİLGİSAYAR ADI" FontSize="10" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SystemInfo.ComputerName}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,20">
                        <TextBlock Text="İŞLETİM SİSTEMİ" FontSize="10" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SystemInfo.OsVersion}" FontSize="14" Foreground="White" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Row 2 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,20">
                        <TextBlock Text="İŞLEMCİ" FontSize="10" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SystemInfo.ProcessorName}" FontSize="14" Foreground="White" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,20">
                        <TextBlock Text="ÇEKİRDEK SAYISI" FontSize="10" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SystemInfo.ProcessorCores}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Row 3 -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,20">
                        <TextBlock Text="TOPLAM RAM" FontSize="10" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SystemInfo.FormattedTotalRam}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,20">
                        <TextBlock Text="KULLANILABİLİR RAM" FontSize="10" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SystemInfo.FormattedAvailableRam}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Row 4 -->
                    <StackPanel Grid.Row="3" Grid.Column="0">
                        <TextBlock Text="TOPLAM DİSK" FontSize="10" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SystemInfo.FormattedTotalDisk}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1">
                        <TextBlock Text="BOŞ DİSK ALANI" FontSize="10" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SystemInfo.FormattedAvailableDisk}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Quick Action -->
            <Button Content="Temizliği Başlat" Style="{StaticResource AccentButton}"
                    Command="{Binding DataContext.NavigateToCleaningCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    HorizontalAlignment="Left" Padding="32,12"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
