<UserControl x:Class="BakimApp.Views.Pages.RegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BakimApp.ViewModels"
             xmlns:models="clr-namespace:BakimApp.Models"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance vm:RegistryViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,32,24">
            <TextBlock Text="Kayit Defteri" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Kayit defterini tarayin ve gereksiz kayitlari temizleyin"
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <!-- Categories Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Categories}" Margin="0,0,32,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:RegistryCategory}">
                        <Border x:Name="CardBorder" Margin="0,0,12,12" Padding="20" CornerRadius="12"
                                BorderThickness="2" Cursor="Hand" MouseLeftButtonUp="CategoryCard_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#18182280"/>
                                    <Setter Property="BorderBrush" Value="#27272A"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.2"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="Background" Value="#1E1E2A80"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Top: Icon + Selected Indicator -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Icon}" FontFamily="Segoe Fluent Icons"
                                                   FontSize="18" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Selected Checkmark -->
                                    <Border x:Name="SelectedCheck" Grid.Column="2" Width="22" Height="22" CornerRadius="11"
                                            Visibility="Collapsed">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                <GradientStop Color="#8B5CF6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <!-- Scanning indicator -->
                                <ProgressBar Grid.Row="0" Height="3" Margin="0,44,0,0" VerticalAlignment="Top"
                                             IsIndeterminate="True" Style="{StaticResource ModernProgress}"
                                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"/>

                                <!-- Middle: Name + Description -->
                                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="#71717A" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Count -->
                                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                                    <TextBlock Text="{Binding ItemCount}" FontSize="28" FontWeight="Bold" Foreground="#6366F1"/>
                                </StackPanel>

                                <!-- Bottom: Status -->
                                <TextBlock Grid.Row="3" Text="{Binding Status}" FontSize="11" Foreground="#71717A" Margin="0,4,0,0"/>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="CardBorder" Property="Background" Value="#1A1A2440"/>
                                <Setter TargetName="SelectedCheck" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Margin="0,16,32,0" CornerRadius="12" Padding="24,20"
                Background="#18182280" BorderBrush="#27272A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Stats -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border CornerRadius="6" Padding="10,4" Margin="0,0,10,0" Background="#10EF4444">
                            <TextBlock FontSize="12" Foreground="#EF4444" FontWeight="SemiBold">
                                <Run Text="{Binding TotalInvalidCount, Mode=OneWay}"/>
                                <Run Text=" Gecersiz"/>
                            </TextBlock>
                        </Border>
                        <Border CornerRadius="6" Padding="10,4" Margin="0,0,10,0" Background="#10F59E0B">
                            <TextBlock FontSize="12" Foreground="#F59E0B" FontWeight="SemiBold">
                                <Run Text="{Binding TotalOrphanedCount, Mode=OneWay}"/>
                                <Run Text=" Yetim"/>
                            </TextBlock>
                        </Border>
                        <Border CornerRadius="6" Padding="10,4" Background="#106366F1">
                            <TextBlock FontSize="12" Foreground="#6366F1" FontWeight="SemiBold">
                                <Run Text="{Binding TotalSelectedCount, Mode=OneWay}"/>
                                <Run Text=" Secili"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#71717A"/>
                    <ProgressBar Height="4" Margin="0,8,0,0" Value="{Binding Progress, Mode=OneWay}" Maximum="100"
                                 Style="{StaticResource ModernProgress}"
                                 Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"/>
                </StackPanel>

                <!-- Right: Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Tara" Style="{StaticResource GhostButton}"
                            Command="{Binding ScanAllCommand}" Margin="0,0,10,0"/>
                    <Button Content="Temizle" Style="{StaticResource AccentButton}"
                            Command="{Binding CleanSelectedCommand}" Margin="0,0,10,0"/>
                    <Button Content="Hepsi" Style="{StaticResource GhostButton}"
                            Command="{Binding SelectAllCommand}" Margin="0,0,10,0"/>
                    <Button Content="Iptal" Style="{StaticResource GhostButton}"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>