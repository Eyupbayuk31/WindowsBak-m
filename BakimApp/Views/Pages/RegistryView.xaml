<UserControl x:Class="BakimApp.Views.Pages.RegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BakimApp.ViewModels"
             xmlns:models="clr-namespace:BakimApp.Models"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance vm:RegistryViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,32,24">
            <TextBlock Text="Kayit Defteri" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Kayit defterini tarayin ve temizleyin"
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <!-- Categories Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Categories}" Margin="0,0,32,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:RegistryCategory}">
                        <Border x:Name="CardBorder" Margin="0,0,12,12" Padding="16" CornerRadius="8"
                                BorderThickness="2" Cursor="Hand" MouseLeftButtonUp="CategoryCard_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#15FFFFFF"/>
                                    <Setter Property="BorderBrush" Value="#30FFFFFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="Background" Value="#20FFFFFF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Top: Icon + Selected Indicator -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon with risk color -->
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RiskLevel}" Value="Safe">
                                                        <Setter Property="Background" Value="#206CCB5F"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RiskLevel}" Value="Caution">
                                                        <Setter Property="Background" Value="#20FCE100"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RiskLevel}" Value="Dangerous">
                                                        <Setter Property="Background" Value="#20F85149"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Icon}" FontFamily="Segoe Fluent Icons"
                                                   FontSize="16" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Selected Checkmark -->
                                    <Border x:Name="SelectedCheck" Grid.Column="2" Width="20" Height="20" CornerRadius="10"
                                            Background="#60CDFF" Visibility="Collapsed">
                                        <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Scanning indicator -->
                                    <ProgressBar Grid.Column="0" Grid.ColumnSpan="3" Height="3" Margin="0,40,0,0" VerticalAlignment="Top"
                                                 IsIndeterminate="True"
                                                 Style="{StaticResource ModernProgress}"
                                                 Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"/>
                                </Grid>

                                <!-- Middle: Name + Description -->
                                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="White" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="#999999" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Bottom: Count + Status -->
                                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                    <TextBlock Text="{Binding ItemCount}" FontSize="20" FontWeight="Bold" Foreground="#60CDFF"/>
                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#666666" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#60CDFF"/>
                                <Setter TargetName="CardBorder" Property="Background" Value="#2060CDFF"/>
                                <Setter TargetName="SelectedCheck" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Background="#15FFFFFF" CornerRadius="8" Padding="24,16" Margin="0,16,32,0"
                BorderBrush="#30FFFFFF" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Stats -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border CornerRadius="4" Padding="8,2" Margin="0,0,8,0" Background="#20F85149">
                            <TextBlock FontSize="11" Foreground="#F85149" FontWeight="SemiBold">
                                <Run Text="{Binding TotalInvalidCount, Mode=OneWay}"/>
                                <Run Text=" Gecersiz"/>
                            </TextBlock>
                        </Border>
                        <Border CornerRadius="4" Padding="8,2" Margin="0,0,8,0" Background="#20FCE100">
                            <TextBlock FontSize="11" Foreground="#FCE100" FontWeight="SemiBold">
                                <Run Text="{Binding TotalOrphanedCount, Mode=OneWay}"/>
                                <Run Text=" Yetim"/>
                            </TextBlock>
                        </Border>
                        <Border CornerRadius="4" Padding="8,2" Background="#2060CDFF">
                            <TextBlock FontSize="11" Foreground="#60CDFF" FontWeight="SemiBold">
                                <Run Text="{Binding TotalSelectedCount, Mode=OneWay}"/>
                                <Run Text=" Secili"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#999999"/>
                </StackPanel>

                <!-- Right: Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Tara" Style="{StaticResource GhostButton}"
                            Command="{Binding ScanAllCommand}" Margin="0,0,8,0"/>
                    <Button Content="Temizle" Style="{StaticResource AccentButton}"
                            Command="{Binding CleanSelectedCommand}" Margin="0,0,8,0"/>
                    <Button Content="Iptal" Style="{StaticResource GhostButton}"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
